# Tap Auto environment variables
# Set these in Vercel (Project > Settings > Environment Variables).
# The api/ serverless functions read them at request time.

# Supabase (Project Settings > API)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key            # safe to expose, RLS protects the data
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # SECRET. server only. never ship to the browser.

# Journey emails (Resend). Set this and the journey buckets start sending.
# Until it is set, /api/send-journey returns configured:false and the app
# just updates the in-app offers without emailing.
# RESEND_API_KEY=re_xxx
# JOURNEY_FROM=Tap Auto <reminders@yourdomain.com>   # must be a Resend-verified sender

# Journey automation (daily cron at 14:00 UTC, see vercel.json).
# CRON_SECRET protects /api/cron-journey; Vercel sends it automatically.
# Offer-flipping runs as soon as the service role key is set. Emailing only
# happens when BOTH RESEND_API_KEY is set AND JOURNEY_AUTOSEND=true (a safety
# switch so connecting Resend for receipts does not start mass-emailing).
# CRON_SECRET=any-long-random-string
# JOURNEY_AUTOSEND=true

# Payments (Stripe). Set these and the /api/stripe/* endpoints go live.
# Until set, they return configured:false and "Collect payment" says so.
# STRIPE_SECRET_KEY=sk_live_or_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx   # from the Stripe webhook pointed at /api/stripe/webhook

# SMS (Twilio) - later
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM=
